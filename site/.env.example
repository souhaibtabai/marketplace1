# ── Local development ─────────────────────────────────────────
# For local dev (both manual and Docker), leave VITE_API_URL empty so the
# Vite proxy handles /api requests → no CORS issues.
# VITE_API_URL=

# For production, set the full backend URL:
# VITE_API_URL=https://marketplacetun.onrender.com

# Dashboard URL (redirect target for admin/vendor login)
# Local:
VITE_DASHBOARD_URL=http://localhost:5174/dashboard
# Production:
# VITE_DASHBOARD_URL=https://marketplace-dashboard-tfqs.onrender.com
