# ── Local development ─────────────────────────────────────────
# Copy this file to .env and adjust the values below.
# When using docker compose, environment is set in docker-compose.yml
# and you do NOT need a .env file.

NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Local PostgreSQL (matches docker-compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketplace
DB_USER=marketplace
DB_PASSWORD=marketplace

# Or use a full DATABASE_URL instead of individual params:
# DATABASE_URL=postgresql://marketplace:marketplace@localhost:5432/marketplace

# JWT — change this before going to production!
JWT_SECRET=local-dev-secret-change-in-production
JWT_EXPIRES_IN=24h
